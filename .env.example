# Set N to your CPU core count (or use local[*] to let Spark decide).
SPARK_MASTER=local[*]
SPARK_APP_NAME=zanbil-preprocess

# Shuffle partition count — only affects aggregation/join stages (benchmark queries).
# Rule of thumb for local mode: N_cores × 2–4. Default 200 is for large clusters.
SPARK_SHUFFLE_PARTITIONS=20

# Extra JVM flags (leave empty unless needed, e.g. -Xmx8g to raise heap).
SPARK_JAVA_OPTS=

# Path to your JDK 21 install. Required if `java` is not already on PATH.
# SDKMAN: sdk home java <version>. macOS: /usr/libexec/java_home -v 21
JAVA_HOME=

# Uncompressed access.log from Kaggle.
RAW_LOG_PATH=data/raw/access.log

# Fraction of lines to parse (Spark sample — approximate). 100 = full file.
RAW_LOG_SAMPLE_PERCENT=100
# Random seed used when RAW_LOG_SAMPLE_PERCENT < 100 (ensures reproducibility).
RAW_LOG_SAMPLE_SEED=42

# Output directory for Snappy Parquet (Spark writes a folder, not a single file).
OUTPUT_PARQUET_PATH=data/processed/access_logs

# Number of Parquet files to write. Target ~128–256 MB/file; for ~3 GB use 16–32.
OUTPUT_PARTITIONS=16

# Partition output by date (recommended — enables pruning for temporal/session queries).
PARTITION_BY_LOG_DATE=true

# Drop rows whose HTTP method is outside the standard verb set (GET/POST/etc).
STRICT_HTTP_METHOD=false

# Local output path for wall-clock benchmark results.
RESULTS_PATH=results/error_pattern_wall_clock.json

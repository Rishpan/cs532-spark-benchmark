# ── GCP Infrastructure ────────────────────────────────────────────────────────
# Used by Makefile gcloud / gsutil commands.

GCP_PROJECT=my-project-id
GCS_BUCKET=my-cs532-bucket
REGION=us-central1
CLUSTER_NAME=cs532-cluster
CLUSTER_WORKERS=2

# Local path to the uncompressed access.log.
# `make stage-raw-log` compresses this to staging/access.log.gz automatically —
# you do not need to gzip it yourself.
RAW_LOG_LOCAL=data/raw/access.log

# ── Spark Session ──────────────────────────────────────────────────────────────
# Used by dataproc/ entrypoints via python-dotenv → session.py.
# SPARK_MASTER=yarn tells session.py we are running on a YARN cluster.
# JAVA_HOME is intentionally omitted — Dataproc nodes have it pre-set as an OS
# environment variable, so require_env() picks it up automatically.

SPARK_MASTER=yarn
SPARK_APP_NAME=zanbil-benchmark
SPARK_SHUFFLE_PARTITIONS=100
SPARK_JAVA_OPTS=

# ── Pipeline Paths (GCS) ───────────────────────────────────────────────────────
# Used by dataproc/ entrypoints and benchmark/wall_clock.py.
# Replace every occurrence of "my-cs532-bucket" with your actual bucket name.

RAW_LOG_PATH=gs://my-cs532-bucket/data/raw/access.log.gz
RAW_LOG_SAMPLE_PERCENT=100
RAW_LOG_SAMPLE_SEED=42

OUTPUT_PARQUET_PATH=gs://my-cs532-bucket/data/processed/access_logs
OUTPUT_PARTITIONS=16
PARTITION_BY_LOG_DATE=true
STRICT_HTTP_METHOD=false

# ── Benchmark Output ───────────────────────────────────────────────────────────
RESULTS_PATH=gs://my-cs532-bucket/results/error_pattern_wall_clock.json
